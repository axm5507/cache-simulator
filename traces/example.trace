# Example memory access trace
# Format: <op> <hex-address>
#   R = read,  W = write
#
# This trace exercises cold misses, cache hits, write-back dirty eviction,
# and temporal locality in a loop-like access pattern.

# --- Cold start: first pass loads all lines ---
R 0x00000000
R 0x00000040
R 0x00000080
R 0x000000C0
W 0x00001000
W 0x00001040

# --- Temporal locality: repeated reads become hits ---
R 0x00000000
R 0x00000040
R 0x00000080
R 0x000000C0

# --- New addresses cause further misses ---
R 0x00002000
R 0x00003000
R 0x00004000

# --- Write then read same line (hit after write-allocate) ---
W 0x00005000
R 0x00005000

# --- Conflict: same set, different tags ---
R 0x00000000
R 0x00008000
R 0x00010000
R 0x00018000
R 0x00020000

# --- Final pass: check which earlier lines survived ---
R 0x00000000
R 0x00001000
R 0x00002000
